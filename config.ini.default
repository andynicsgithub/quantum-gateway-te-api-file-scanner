[DEFAULT]
input_directory = /path/to/source/files
reports_directory = /path/to/directory/for/report/files
appliance_ip = 192.168.1.1
benign_directory = /path/to/directory/for/safe/files
quarantine_directory = /path/to/quarantine
error_directory = /path/to/directory/for/files/that/error
concurrency = 4
seconds_to_wait = 10

[LOGGING]
log_level = INFO
log_dir = ./logs
max_log_size_mb = 10
backup_count = 5
